generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEN    String
  nameFR    String
  descEN    String
  descFR    String
  price     Int
  image     String
  model3d   String?
  stockQuantity Int?
  bundleQuantity Int?
  bundlePrice Int?
  filamentGrams Int @default(187)
  printTimeMinutes Int @default(240)
  productionCost Int @default(90)
  category  String
  inStock   Boolean  @default(true)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orders    Order[]
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique
  type        String
  value       Int
  minTotal    Int      @default(0)
  active      Boolean  @default(true)
  usageLimit  Int?
  usedCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductionItem {
  id          String   @id @default(cuid())
  name        String
  type        String
  status      String
  quantity    Int      @default(0)
  unit        String
  unitCost    Int      @default(0)
  monthlyCost Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id              String      @id @default(cuid())
  customerName    String
  customerPhone   String
  customerCity    String
  customerAddress String
  productId       String
  product         Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  productName     String
  productPrice    Int
  quantity        Int
  totalPrice      Int
  status          String      @default("pending")
  notes           String?
  createdAt       DateTime    @default(now())
}
